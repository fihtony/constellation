{
  "agentId": "web-agent",
  "cardUrl": "http://web-agent:8050/.well-known/agent-card.json",
  "executionMode": "per-task",
  "launchSpec": {
    "image": "constellation-web-agent:latest",
    "port": 8050,
    "command": ["python3", "web/app.py"],
    "passThroughEnv": ["ARTIFACT_ROOT_HOST", "ARTIFACT_ROOT", "DYNAMIC_AGENT_NETWORK", "COPILOT_GITHUB_TOKEN"],
    "env": {
      "OPENAI_BASE_URL": "http://host.docker.internal:1288/v1",
      "OPENAI_MODEL": "gpt-5-mini",
      "ALLOW_MOCK_FALLBACK": "1"
    }
  },
  "scalingPolicy": {
    "maxInstances": 3,
    "perInstanceConcurrency": 1,
    "idleTimeoutSeconds": 120
  }
}
