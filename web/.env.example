# Web Agent — environment variable template, all optional with defaults
# Copy to .env and fill in the values before running.

# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_ID=web-agent
ADVERTISED_BASE_URL=http://web-agent:8050

# ── Registry ──────────────────────────────────────────────────────────────────
REGISTRY_URL=http://registry:9000

# ── Downstream agent URLs ─────────────────────────────────────────────────────
# SCM Agent for repo clone, branch create, file push, and PR creation
SCM_AGENT_URL=http://scm:8020
# Tracker / Jira Agent for ticket context
JIRA_AGENT_URL=http://tracker:8010
# Compass URL for progress reporting
COMPASS_URL=http://compass:8080

# ── LLM (use host.docker.internal for Docker Desktop) ────────────────────────
OPENAI_BASE_URL=http://host.docker.internal:1288/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
# Set to 1 to use deterministic mock responses (offline/unit testing)
ALLOW_MOCK_FALLBACK=1

# ── Runtime ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8050
HEARTBEAT_INTERVAL=30
A2A_ACK_TIMEOUT_SECONDS=15
A2A_TASK_TIMEOUT_SECONDS=600
SYNC_AGENT_TIMEOUT_SECONDS=120
