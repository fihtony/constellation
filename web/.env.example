# Web Agent - Minimal Configuration
# Launched as a per-task container; most settings come from docker-compose.

# [OPTIONAL] LLM endpoint
#   Leave unset to use runtime-aware defaults:
#   - standalone local debug: http://localhost:1288/v1
#   - Docker container: http://host.docker.internal:1288/v1
#   - Rancher container: http://host.rancher-desktop.internal:1288/v1
# OPENAI_BASE_URL=

# [OPTIONAL] Agentic runtime backend
#   Default for per-task execution: copilot-cli
#   Other supported values: claude-code | copilot-connect | mock
# AGENT_RUNTIME=copilot-cli

# [OPTIONAL] Runtime model override (higher priority than OPENAI_MODEL)
# AGENT_MODEL=gpt-5-mini

# [OPTIONAL] Model name  (default: gpt-5-mini)
# OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] API key (leave blank if endpoint does not require one)
# OPENAI_API_KEY=

# [OPTIONAL] Allow mock fallback — for offline/test environments ONLY. Keep disabled in dev and prod.
ALLOW_MOCK_FALLBACK=0

# [OPTIONAL] GitHub PAT for Copilot CLI (normally passed through from Compass)
# COPILOT_GITHUB_TOKEN=github_pat_...
