{
  "agentId": "team-lead-agent",
  "cardUrl": "http://team-lead-agent:8030/.well-known/agent-card.json",
  "executionMode": "per-task",
  "launchSpec": {
    "image": "constellation-team-lead-agent:latest",
    "port": 8030,
    "command": ["python3", "team-lead/app.py"],
    "mountDockerSocket": true,
    "passThroughEnv": ["ARTIFACT_ROOT", "COPILOT_GITHUB_TOKEN", "TZ"],
    "env": {
      "COMPASS_URL": "http://compass:8080",
      "DYNAMIC_AGENT_NETWORK": "constellation-network"
    }
  },
  "scalingPolicy": {
    "maxInstances": 5,
    "perInstanceConcurrency": 1,
    "idleTimeoutSeconds": 300
  }
}
