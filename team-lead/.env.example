# Team Lead Agent — environment variable template
# Copy to .env and fill in the values before running.

# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_ID=team-lead-agent
ADVERTISED_BASE_URL=http://team-lead:8030

# ── Registry ──────────────────────────────────────────────────────────────────
REGISTRY_URL=http://registry:9000

# ── Downstream agent URLs ─────────────────────────────────────────────────────
# Jira / Tracker agent (handles jira.ticket.fetch etc.)
JIRA_AGENT_URL=http://tracker:8010
# UI Design agent (handles figma.page.fetch, stitch.screen.fetch etc.)
UI_DESIGN_AGENT_URL=http://ui-design:8040
# Compass URL used for progress reporting
COMPASS_URL=http://compass:8080

# ── LLM (use host.docker.internal for Docker Desktop) ────────────────────────
OPENAI_BASE_URL=http://host.docker.internal:1288/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
# Set to 1 to use deterministic mock responses (offline/unit testing)
ALLOW_MOCK_FALLBACK=1

# ── Runtime ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8030
HEARTBEAT_INTERVAL=30

# ── Workflow tuning ───────────────────────────────────────────────────────────
# Maximum code review cycles before accepting the output
MAX_REVIEW_CYCLES=2
# Seconds to wait for user input before failing an INPUT_REQUIRED task
INPUT_WAIT_TIMEOUT_SECONDS=7200
# Seconds to wait for a sync agent (Jira, UI Design) response
SYNC_AGENT_TIMEOUT_SECONDS=120
# ACK timeout for A2A calls
A2A_ACK_TIMEOUT_SECONDS=15
# Total timeout for the full task (covers dev agent execution)
A2A_TASK_TIMEOUT_SECONDS=3600
