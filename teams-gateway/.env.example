# Agent identity
AGENT_ID=teams-gateway
ADVERTISED_BASE_URL=http://teams-gateway:8070

# Registry
REGISTRY_URL=http://registry:9000

# Compass
COMPASS_URL=http://compass:8080
COMPASS_API_KEY=

# Microsoft Bot Framework
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=

# SQLite persistence
TEAMS_GATEWAY_DB_PATH=/app/data/teams-gateway/teams-gateway.db

# Rate limiting
MAX_TASKS_PER_USER=5
RATE_LIMIT_PER_MINUTE=3
MAX_MESSAGE_LENGTH=4000

# Runtime
HOST=0.0.0.0
PORT=8070
