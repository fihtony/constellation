# ============================================================================
# Claude Code CLI / Agentic CLI Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
# The .env file is gitignored - NEVER commit actual credentials.
#
# HOW TO USE DIFFERENT AGENTIC CLI BACKENDS:
# ---------------------------------------------------
# Set AGENT_RUNTIME to choose which CLI backend to use:
#   claude-code  - Claude Code CLI (local claude binary)
#   copilot-cli  - GitHub Copilot CLI
#   connect-agent - Connect Agent HTTP backend
#
# Each backend requires different environment variables.
# Mandatory variables are marked with (M), Optional with (O).
# Default values are shown in brackets [].
# ============================================================================

# --------------------------------------------------------------------------
# COMMON SETTINGS (required by all backends)
# --------------------------------------------------------------------------
AGENT_RUNTIME=claude-code          # (M) Agentic CLI backend: claude-code | copilot-cli | connect-agent

# --------------------------------------------------------------------------
# CLAUDE CODE CLI (when AGENT_RUNTIME=claude-code)
# --------------------------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=              # (M) Anthropic API token
ANTHROPIC_BASE_URL=               # (O) API base URL [https://api.minimaxi.com/anthropic]
ANTHROPIC_MODEL=                  # (O) Default model [MiniMax-M2.7]
ANTHROPIC_DEFAULT_HAIKU_MODEL=    # (O) Default Haiku model [MiniMax-M2.7]
ANTHROPIC_DEFAULT_SONNET_MODEL=   # (O) Default Sonnet model [MiniMax-M2.7]
ANTHROPIC_DEFAULT_OPUS_MODEL=     # (O) Default Opus model [MiniMax-M2.7]
API_TIMEOUT_MS=                   # (O) API timeout in ms [3000000]
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=  # (O) Disable non-essential traffic [1]

# --------------------------------------------------------------------------
# COPILOT CLI (when AGENT_RUNTIME=copilot-cli)
# --------------------------------------------------------------------------
GH_TOKEN=                         # (M) GitHub personal access token
COPILOT_GITHUB_TOKEN=             # (M) Copilot GitHub token

# --------------------------------------------------------------------------
# CONNECT AGENT (when AGENT_RUNTIME=connect-agent)
# --------------------------------------------------------------------------
CONNECT_AGENT_URL=               # (M) Connect Agent backend URL [http://localhost:8000]
CONNECT_AGENT_TOKEN=             # (O) Connect Agent auth token

# --------------------------------------------------------------------------
# CONTAINER RUNTIME
# --------------------------------------------------------------------------
CONTAINER_RUNTIME=               # (O) Container runtime: docker | rancher [docker]
                                 # rancher = use ~/.rd/docker.sock (Rancher Desktop)
                                 # docker = use /var/run/docker.sock (Docker Desktop)
