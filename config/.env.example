# Constellation v2 Environment Configuration

# Runtime backend (connect-agent is the default and only supported backend in company env)
AGENT_RUNTIME=connect-agent
AGENT_MODEL=gpt-5.4-mini

# OpenAI-compatible API (Copilot Connect)
# Leave unset for auto-detection:
#   localhost on host, host.docker.internal in Docker,
#   host.rancher-desktop.internal in Rancher
# OPENAI_BASE_URL=http://localhost:1288/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

# Container runtime: docker | rancher
CONTAINER_RUNTIME=rancher

# Timezone
LOCAL_TIMEZONE=America/Toronto

# Registry
REGISTRY_URL=http://registry:9000

# Data directory (gitignored)
DATA_DIR=data
