# ============================================================================
# Constellation — global configuration overrides
# ============================================================================
# Copy this file to config/.env and fill in the values.
# config/.env is gitignored — NEVER commit actual credentials.
#
# PURPOSE OF THIS FILE
# --------------------
# This file overrides system defaults from config/constellation.yaml for a
# specific machine / deployment environment.  It covers:
#   1. Shared selectors  — agentic runtime, container runtime, boundary backends
#   2. Runtime-specific credentials / URLs (only for the active runtime)
#   3. Deployment-specific overrides that differ from the repo defaults
#
# Agent-local secrets (Jira token, SCM token, Figma key, etc.) stay in
# agents/<agent>/.env — NOT here.  Shared selectors (JIRA_BACKEND, SCM_BACKEND,
# UI_DESIGN_DEFAULT_PROVIDER, AGENT_RUNTIME, CONTAINER_RUNTIME) must NOT be
# redefined in agent-level .env files.
#
# Mandatory items are marked (M), Optional items with (O).
# Default values are shown in brackets [default].
# ============================================================================

# --------------------------------------------------------------------------
# AGENTIC RUNTIME BACKEND SELECTOR
# Supported values: claude-code | copilot-cli | codex-cli | connect-agent
# Default (in constellation.yaml): claude-code
# --------------------------------------------------------------------------
AGENT_RUNTIME=claude-code          # (M) Active agentic runtime backend

# Generic fallback model — used when the active runtime has no dedicated model.
# Runtime-specific model env vars (e.g. ANTHROPIC_MODEL) take priority over this.
# AGENT_MODEL=                     # (O) Generic model override [see constellation.yaml]

# --------------------------------------------------------------------------
# BOUNDARY BACKEND SELECTORS
# These are global deployment selectors — override constellation.yaml defaults.
# Do NOT define these keys in agents/<agent>/.env.
# --------------------------------------------------------------------------
# JIRA_BACKEND=mcp                 # (O) Jira backend: mcp | rest  [mcp]
# SCM_BACKEND=github-mcp           # (O) SCM backend: bitbucket | github-rest | github-mcp  [github-mcp]
# UI_DESIGN_DEFAULT_PROVIDER=stitch  # (O) UI design provider: stitch | figma  [stitch]

# --------------------------------------------------------------------------
# CONTAINER RUNTIME
# Supported values: docker | rancher
# Default (in constellation.yaml): docker
# --------------------------------------------------------------------------
# CONTAINER_RUNTIME=docker         # (O) Container runtime: docker | rancher  [docker]

# --------------------------------------------------------------------------
# DEFAULT TIMEZONE
# IANA name (e.g. America/Toronto, America/New_York, Asia/Shanghai, UTC).
# Sets the wall-clock zone every agent container uses when it writes a
# devlog line or a server-emitted timestamp. The default in
# constellation.yaml is ``America/Toronto``; the docker compose file
# falls back to that same value if this variable is unset, so an empty
# config/.env still produces Toronto-time log lines. Set this to the
# IANA name of your local zone to see agent.log timestamps in your
# own clock instead.
# --------------------------------------------------------------------------
# TZ=America/Toronto              # (O) Default agent timezone  [America/Toronto]

# --------------------------------------------------------------------------
# CLAUDE CODE CLI (active when AGENT_RUNTIME=claude-code)
# Keep commented out when AGENT_RUNTIME != claude-code.
# --------------------------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=              # (M) Anthropic API token
# ANTHROPIC_BASE_URL=              # (O) API base URL [https://api.anthropic.com]
# ANTHROPIC_MODEL=                 # (O) Default model — overrides AGENT_MODEL when set
# ANTHROPIC_DEFAULT_HAIKU_MODEL=   # (O) Haiku model override
# ANTHROPIC_DEFAULT_SONNET_MODEL=  # (O) Sonnet model override
# ANTHROPIC_DEFAULT_OPUS_MODEL=    # (O) Opus model override
# API_TIMEOUT_MS=                  # (O) API timeout in ms [300000]
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=  # (O) Disable non-essential traffic [1]

# --------------------------------------------------------------------------
# COPILOT CLI (active when AGENT_RUNTIME=copilot-cli)
# Keep commented out when AGENT_RUNTIME != copilot-cli.
# --------------------------------------------------------------------------
# COPILOT_GITHUB_TOKEN=            # (M) GitHub token for Copilot CLI auth

# --------------------------------------------------------------------------
# CODEX CLI (active when AGENT_RUNTIME=codex-cli)
# Keep commented out when AGENT_RUNTIME != codex-cli.
# (Actual variable names depend on the final codex-cli contract)
# --------------------------------------------------------------------------
# CODEX_API_KEY=                   # (M) Codex API key

# --------------------------------------------------------------------------
# CONNECT AGENT (active when AGENT_RUNTIME=connect-agent)
# Keep commented out when AGENT_RUNTIME != connect-agent.
# When unset, the runtime resolves a default based on where the process runs:
#   host process    -> http://localhost:1288
#   Docker container  -> http://host.docker.internal:1288
#   Rancher container -> http://host.rancher-desktop.internal:1288
# --------------------------------------------------------------------------
# CONNECT_AGENT_URL=               # (O) Connect Agent base URL [auto-resolved per above]
# CONNECT_AGENT_TOKEN=             # (O) Connect Agent auth token
