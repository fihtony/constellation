# Compass Agent — claude-code backend
# Extends constellation-base-claude-code with compass agent code.
# Select this Dockerfile when AGENT_RUNTIME=claude-code.

FROM constellation-base-claude-code:latest

COPY compass/ /app/compass/

LABEL constellation.agent_id="compass-agent"
LABEL constellation.agent_name="Compass Agent"
LABEL constellation.agent_role="fundamental"
LABEL constellation.runtime.backend="claude-code"

RUN chown -R appuser:appuser /app
USER appuser

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "compass/app.py"]
