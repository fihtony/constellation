# =============================================================================
# Compass Agent — Environment Configuration
# Copy this file to .env and fill in the required values.
#
# Legend:  [REQUIRED] must be set for the agent to function correctly
#          [OPTIONAL] has a default; override only when needed
# =============================================================================

# -----------------------------------------------------------------------------
# Downstream agent credentials  (required for real system integration)
# -----------------------------------------------------------------------------

# [REQUIRED] Token for the SCM (Bitbucket/GitHub) agent
SCM_TOKEN=replace-with-scm-token

# [REQUIRED] Token for the Tracker (Jira) agent
TRACKER_TOKEN=replace-with-tracker-token

# [OPTIONAL] Email used when Tracker requires Basic auth (email:token)
TRACKER_EMAIL=tracker-user@example.com

# -----------------------------------------------------------------------------
# Agent identity
# -----------------------------------------------------------------------------

# [OPTIONAL] Bind address — 0.0.0.0 to listen on all interfaces
HOST=0.0.0.0

# [OPTIONAL] Port the agent listens on
PORT=8080

# [OPTIONAL] URL that other agents use to reach this instance
ADVERTISED_BASE_URL=http://compass:8080

# [OPTIONAL] Capability Registry URL
REGISTRY_URL=http://registry:9000

# -----------------------------------------------------------------------------
# Workflow timeouts
# -----------------------------------------------------------------------------

# [OPTIONAL] Seconds to wait for an ACK from a downstream agent
A2A_ACK_TIMEOUT_SECONDS=15

# [OPTIONAL] Maximum wall-clock seconds for a complete task
A2A_TASK_TIMEOUT_SECONDS=3600

# [OPTIONAL] Root directory for artifact files
ARTIFACT_ROOT=/app/artifacts

# -----------------------------------------------------------------------------
# Dynamic-agent launcher (Docker socket)
# -----------------------------------------------------------------------------

# [OPTIONAL] Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# [OPTIONAL] Default image for on-demand execution agents
DEFAULT_DYNAMIC_IMAGE=constellation-android-agent:latest

# [OPTIONAL] Docker network shared by all constellation containers
DYNAMIC_AGENT_NETWORK=constellation-network

# [OPTIONAL] Port inside the dynamic agent container
DYNAMIC_AGENT_PORT=8000

# -----------------------------------------------------------------------------
# LLM backend
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenAI-compatible endpoint
OPENAI_BASE_URL=http://host.docker.internal:1288/v1

# [OPTIONAL] Model name served at OPENAI_BASE_URL
OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] API key — leave blank when the endpoint handles auth differently
OPENAI_API_KEY=

# [OPTIONAL] Set to 1 to return a mock LLM response when the endpoint is down
ALLOW_MOCK_FALLBACK=1