# Compass Agent - Minimal Configuration
# Most settings are injected by docker-compose. Override here only when needed.

# [OPTIONAL] Root directory for artifact storage  (default: /app/artifacts)
# ARTIFACT_ROOT=/app/artifacts

# [REQUIRED] Host path of the artifacts directory, used to bind-mount into
# per-task containers launched by Compass via Docker socket.
# Example (macOS): ARTIFACT_ROOT_HOST=/Users/yourname/projects/constellation/artifacts
ARTIFACT_ROOT_HOST=

# [OPTIONAL] LLM endpoint  (default: http://host.docker.internal:1288/v1)
# OPENAI_BASE_URL=http://host.docker.internal:1288/v1

# [OPTIONAL] Model name  (default: gpt-5-mini)
# OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] GitHub PAT used by the Copilot CLI code path inside containers.
#   - Required only when you want agents to use the GitHub Copilot CLI LLM tier.
#   - Must have the "Copilot Requests" permission.
#   - Compass passes this to per-task containers (team-lead, web) automatically
#     via passThroughEnv in registry-config.json — you do NOT need to copy it
#     to every agent's .env file.  Set it here once.
# COPILOT_GITHUB_TOKEN=github_pat_...
