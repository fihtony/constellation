# Mandatory when the Compass agent needs to fan out to real enterprise systems.
SCM_TOKEN=replace-with-scm-token
TRACKER_TOKEN=replace-with-tracker-token

# Optional but recommended when Tracker uses raw tokens that need Basic auth.
TRACKER_EMAIL=tracker-user@example.com

# Optional LLM settings.
OPENAI_BASE_URL=http://host.docker.internal:1288/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
ALLOW_MOCK_FALLBACK=1

# Optional Compass agent runtime defaults.
HOST=0.0.0.0
PORT=8080
ADVERTISED_BASE_URL=http://localhost:8080
REGISTRY_URL=http://registry:9000
A2A_ACK_TIMEOUT_SECONDS=15
A2A_TASK_TIMEOUT_SECONDS=3600
ARTIFACT_ROOT=/app/artifacts

# Optional dynamic-agent launcher defaults.
DOCKER_SOCKET=/var/run/docker.sock
DEFAULT_DYNAMIC_IMAGE=mvp-android-agent:latest
DYNAMIC_AGENT_NETWORK=mvp-network
DYNAMIC_AGENT_PORT=8000