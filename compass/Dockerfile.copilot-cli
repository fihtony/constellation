# Compass Agent — copilot-cli backend
# Extends constellation-base-copilot-cli with compass agent code.
# Select this Dockerfile when AGENT_RUNTIME=copilot-cli (the default).

FROM constellation-base-copilot-cli:latest

COPY compass/ /app/compass/

LABEL constellation.agent_id="compass-agent"
LABEL constellation.agent_name="Compass Agent"
LABEL constellation.agent_role="fundamental"
LABEL constellation.runtime.backend="copilot-cli"

RUN chown -R appuser:appuser /app
USER appuser

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "compass/app.py"]
