# =============================================================================
# Bitbucket Agent — Environment Configuration
# Copy this file to .env and fill in the required values.
#
# Legend:  [REQUIRED] must be set for the agent to function correctly
#          [OPTIONAL] has a default; override only when needed
# =============================================================================

# -----------------------------------------------------------------------------
# Bitbucket Server credentials
# -----------------------------------------------------------------------------

# [REQUIRED] Bitbucket personal access token (used as Bearer token)
BITBUCKET_TOKEN=replace-with-bitbucket-token

# [OPTIONAL] Username — required only when BITBUCKET_AUTH_MODE=basic
BITBUCKET_USERNAME=

# [OPTIONAL] Auth mode: auto | bearer | basic
BITBUCKET_AUTH_MODE=auto

# -----------------------------------------------------------------------------
# Bitbucket instance configuration
# -----------------------------------------------------------------------------

# [OPTIONAL] Base URL of your Bitbucket Server project
#   Example: https://bitbucket.example.com/projects/MYPROJECT
BITBUCKET_BASE_URL=https://bitbucket.example.com/projects/MYPROJECT

# [OPTIONAL] REST API root — derived from BITBUCKET_BASE_URL when omitted
#   Example: https://bitbucket.example.com/rest/api/1.0
BITBUCKET_REST_API=https://bitbucket.example.com/rest/api/1.0

# [OPTIONAL] Override the full API base URL (rarely needed)
BITBUCKET_API_BASE_URL=

# -----------------------------------------------------------------------------
# Agent identity
# -----------------------------------------------------------------------------

# [OPTIONAL] Bind address
HOST=0.0.0.0

# [OPTIONAL] Port the agent listens on
PORT=8020

# [OPTIONAL] Unique agent identifier — must match registry-config.json
AGENT_ID=bitbucket-agent

# [OPTIONAL] URL that other agents use to reach this instance
ADVERTISED_BASE_URL=http://bitbucket:8020

# [OPTIONAL] Capability Registry URL
REGISTRY_URL=http://registry:9000

# [OPTIONAL] Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# [OPTIONAL] Set to 0 to disable registry heartbeat (useful for unit tests)
INSTANCE_REPORTER_ENABLED=1

# -----------------------------------------------------------------------------
# Git author identity (used when pushing commits)
# -----------------------------------------------------------------------------

# [OPTIONAL] Author name for agent commits
BITBUCKET_GIT_AUTHOR_NAME=Bitbucket Agent

# [OPTIONAL] Author email for agent commits
BITBUCKET_GIT_AUTHOR_EMAIL=bitbucket-agent@local

# -----------------------------------------------------------------------------
# LLM backend
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenAI-compatible endpoint
OPENAI_BASE_URL=http://host.docker.internal:1288/v1

# [OPTIONAL] Model name served at OPENAI_BASE_URL
OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] API key — leave blank when the endpoint handles auth differently
OPENAI_API_KEY=

# [OPTIONAL] Set to 1 to return a mock LLM response when the endpoint is down
ALLOW_MOCK_FALLBACK=1