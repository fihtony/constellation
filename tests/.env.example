# =============================================================================
# Test Configuration
# Copy this file to tests/.env (gitignored) and fill in your values.
# The test suite parses URLs automatically — you do not need to extract IDs manually.
# =============================================================================

# =============================================================================
# Jira Cloud
# Paste the full ticket URL — base URL and ticket key are parsed automatically.
#   Example: https://your-org.atlassian.net/browse/PROJ-1
# =============================================================================
TEST_JIRA_TICKET_URL=https://your-org.atlassian.net/browse/PROJ-1

# Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
TEST_JIRA_TOKEN=

# Atlassian account email (used with TEST_JIRA_TOKEN for Basic auth)
TEST_JIRA_EMAIL=

# =============================================================================
# GitHub
# Paste the full repository URL — owner and repo name are parsed automatically.
#   Example: https://github.com/your-username/test-repo
# =============================================================================
TEST_GITHUB_REPO_URL=https://github.com/your-username/test-repo

# GitHub personal access token (scope: repo)
TEST_GITHUB_TOKEN=

# =============================================================================
# Figma
# Paste the full file or design URL — file key is parsed automatically.
#   Example: https://www.figma.com/design/abc123XYZ/My-Design
# =============================================================================
TEST_FIGMA_FILE_URL=https://www.figma.com/design/your-file-key/My-Design

# Figma personal access token — generate at figma.com > Account Settings > Personal access tokens
TEST_FIGMA_TOKEN=

# =============================================================================
# Google Stitch
# Paste the full project URL — project ID is parsed automatically.
#   Example: https://stitch.withgoogle.com/projects/12345678
# Screen ID is still needed separately (visible in the Stitch UI or screen URL).
# =============================================================================
TEST_STITCH_PROJECT_URL=https://stitch.withgoogle.com/projects/your-project-id

TEST_STITCH_SCREEN_ID=your-screen-id

# Google / Gemini API key — obtain at https://aistudio.google.com/app/apikey
TEST_STITCH_API_KEY=
