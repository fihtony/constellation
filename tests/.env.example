# Test Configuration - copy to tests/.env and fill in your values.

# Jira Cloud
TEST_JIRA_TICKET_URL=https://your-org.atlassian.net/browse/PROJ-1
TEST_JIRA_TOKEN=
TEST_JIRA_EMAIL=

# GitHub
TEST_GITHUB_REPO_URL=https://github.com/your-username/test-repo
TEST_GITHUB_TOKEN=

# Figma
TEST_FIGMA_FILE_URL=https://www.figma.com/design/your-file-key/My-Design
TEST_FIGMA_TOKEN=

# Google Stitch
TEST_STITCH_PROJECT_URL=https://stitch.withgoogle.com/projects/your-project-id
TEST_STITCH_SCREEN_ID=your-screen-id
TEST_STITCH_API_KEY=

# LLM (localhost for local tests; host.docker.internal inside containers)
OPENAI_BASE_URL=http://localhost:1288/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
ALLOW_MOCK_FALLBACK=1
