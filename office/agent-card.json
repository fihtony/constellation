{
  "schemaVersion": "1.0",
  "name": "Office Agent",
  "description": "Per-task document agent for local office files. Summarizes documents, analyzes spreadsheets/CSV data, and organizes user-authorized folders through a bounded execution plan.",
  "version": "1.0.0",
  "supportedInterfaces": [
    {
      "url": "__ADVERTISED_URL__",
      "protocolBinding": "HTTP+JSON",
      "protocolVersion": "1.0"
    }
  ],
  "capabilities": {
    "streaming": false,
    "pushNotifications": true
  },
  "defaultInputModes": ["text/plain"],
  "defaultOutputModes": ["text/plain"],
  "skills": [
    {
      "id": "office.document.summarize",
      "name": "Office Document Summarize",
      "description": "Summarizes one or more local office documents into a Markdown report.",
      "executionMode": "async",
      "asyncContract": {
        "callbackField": "orchestratorCallbackUrl",
        "taskIdField": "taskId",
        "pollEndpoint": "GET /tasks/{taskId}",
        "callbackPayloadSchema": {
          "downstreamTaskId": "string",
          "state": "TASK_STATE_COMPLETED | TASK_STATE_FAILED",
          "statusMessage": "string",
          "artifacts": "array",
          "agentId": "string"
        }
      },
      "tags": ["office", "document", "summary", "markdown", "async"]
    },
    {
      "id": "office.folder.summarize",
      "name": "Office Folder Summarize",
      "description": "Summarizes a folder of local documents into a single Markdown report.",
      "executionMode": "async",
      "asyncContract": {
        "callbackField": "orchestratorCallbackUrl",
        "taskIdField": "taskId",
        "pollEndpoint": "GET /tasks/{taskId}",
        "callbackPayloadSchema": {
          "downstreamTaskId": "string",
          "state": "TASK_STATE_COMPLETED | TASK_STATE_FAILED",
          "statusMessage": "string",
          "artifacts": "array",
          "agentId": "string"
        }
      },
      "tags": ["office", "folder", "summary", "markdown", "async"]
    },
    {
      "id": "office.data.analyze",
      "name": "Office Data Analyze",
      "description": "Analyzes CSV and spreadsheet data and produces a Markdown report with findings.",
      "executionMode": "async",
      "asyncContract": {
        "callbackField": "orchestratorCallbackUrl",
        "taskIdField": "taskId",
        "pollEndpoint": "GET /tasks/{taskId}",
        "callbackPayloadSchema": {
          "downstreamTaskId": "string",
          "state": "TASK_STATE_COMPLETED | TASK_STATE_FAILED",
          "statusMessage": "string",
          "artifacts": "array",
          "agentId": "string"
        }
      },
      "tags": ["office", "csv", "xlsx", "analysis", "async"]
    },
    {
      "id": "office.folder.organize",
      "name": "Office Folder Organize",
      "description": "Creates a bounded organize plan for a local folder and executes it within the user-authorized scope.",
      "executionMode": "async",
      "asyncContract": {
        "callbackField": "orchestratorCallbackUrl",
        "taskIdField": "taskId",
        "pollEndpoint": "GET /tasks/{taskId}",
        "callbackPayloadSchema": {
          "downstreamTaskId": "string",
          "state": "TASK_STATE_COMPLETED | TASK_STATE_FAILED",
          "statusMessage": "string",
          "artifacts": "array",
          "agentId": "string"
        }
      },
      "tags": ["office", "folder", "organize", "plan", "async"]
    }
  ]
}