# Office Agent — copilot-cli backend
# Extends constellation-base-copilot-cli with office agent code and document libs.
# Select this Dockerfile when AGENT_RUNTIME=copilot-cli (the default).

FROM constellation-base-copilot-cli:latest

RUN pip install --no-cache-dir \
    pypdf \
    pdfplumber \
    python-docx \
    python-pptx \
    openpyxl \
    xlrd \
    chardet

COPY office/ /app/office/

LABEL constellation.agent_id="office-agent"
LABEL constellation.agent_name="Office Agent"
LABEL constellation.agent_role="execution"
LABEL constellation.runtime.backend="copilot-cli"

RUN chown -R appuser:appuser /app
USER appuser

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "office/app.py"]
