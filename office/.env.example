# Office Agent - Minimal Configuration
# Launched as a per-task container; most settings come from Compass and common/.env.

# [OPTIONAL] LLM endpoint
# OPENAI_BASE_URL=

# [OPTIONAL] Agentic runtime backend
# AGENT_RUNTIME=copilot-cli

# [OPTIONAL] Runtime model override
# AGENT_MODEL=gpt-5-mini

# [OPTIONAL] Model name
# OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] API key for OpenAI-compatible endpoints
# OPENAI_API_KEY=

# [OPTIONAL] Allow mock fallback — for offline/test environments ONLY. Keep disabled in dev and prod.
ALLOW_MOCK_FALLBACK=0

# [OPTIONAL] GitHub PAT for Copilot CLI (normally passed through from Compass)
# COPILOT_GITHUB_TOKEN=github_pat_...

# [OPTIONAL] Single-file size limit in MB
# OFFICE_MAX_FILE_SIZE_MB=50

# [OPTIONAL] Directory preflight limits
# OFFICE_MAX_DIR_FILE_COUNT=2000
# OFFICE_MAX_DIR_TOTAL_MB=250