# UI Design Agent — claude-code backend
# Extends constellation-base-claude-code with ui-design agent code.
# Select this Dockerfile when AGENT_RUNTIME=claude-code.

FROM constellation-base-claude-code:latest

COPY ui-design/  /app/ui-design/

LABEL constellation.agent_id="ui-design-agent"
LABEL constellation.agent_name="UI Design Agent"
LABEL constellation.agent_role="integration"
LABEL constellation.runtime.backend="claude-code"

RUN chown -R appuser:appuser /app
USER appuser

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "ui-design/app.py"]
