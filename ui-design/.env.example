# =============================================================================
# UI Design Agent — Environment Configuration
# Copy this file to .env and fill in the required values.
#
# Legend:  [REQUIRED] must be set for the agent to function correctly
#          [OPTIONAL] has a default; override only when needed
# =============================================================================

# -----------------------------------------------------------------------------
# Design-source credentials
# -----------------------------------------------------------------------------

# [REQUIRED] Figma personal access token — generate at:
#   https://www.figma.com/settings → Personal access tokens
FIGMA_TOKEN=replace-with-figma-personal-access-token

# [REQUIRED] Google Stitch / Gemini API key — obtain at:
#   https://aistudio.google.com/app/apikey
STITCH_API_KEY=replace-with-google-stitch-api-key

# -----------------------------------------------------------------------------
# Agent identity  (change only if running multiple instances)
# -----------------------------------------------------------------------------

# [OPTIONAL] Unique agent identifier — must match registry-config.json
#   Default: ui-design-agent
AGENT_ID=ui-design-agent

# [OPTIONAL] URL that other agents use to reach this instance
#   Local:     http://localhost:8040
#   Docker:    http://ui-design:8040
#   Default:   http://ui-design:8040
ADVERTISED_BASE_URL=http://ui-design:8040

# [OPTIONAL] Capability Registry URL
#   Default: http://registry:9000
REGISTRY_URL=http://registry:9000

# -----------------------------------------------------------------------------
# Network / runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Bind address — 0.0.0.0 to listen on all interfaces
HOST=0.0.0.0

# [OPTIONAL] Port the agent listens on
PORT=8040

# [OPTIONAL] Heartbeat interval in seconds (keep-alive to registry)
HEARTBEAT_INTERVAL=30

# [OPTIONAL] Set to 0 to disable registry heartbeat (useful for unit tests)
INSTANCE_REPORTER_ENABLED=1

# -----------------------------------------------------------------------------
# SSL / TLS  (enterprise / corporate proxy environments)
# -----------------------------------------------------------------------------

# [OPTIONAL] Path to a custom CA bundle (.pem) for outbound HTTPS calls.
#   Required when behind a corporate MITM proxy that intercepts TLS.
#   Example: /app/certs/corp-ca.pem
# CORP_CA_BUNDLE=

# [OPTIONAL] Alternative env var read by Python ssl / requests / urllib3.
#   Set this OR CORP_CA_BUNDLE — both point to the same CA file.
# SSL_CERT_FILE=

# -----------------------------------------------------------------------------
# LLM backend  (used only when the agent needs to summarise design data)
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenAI-compatible endpoint — defaults to local Copilot Connect
OPENAI_BASE_URL=http://host.docker.internal:1288/v1

# [OPTIONAL] Model name served at OPENAI_BASE_URL
OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] API key — leave blank when the endpoint handles auth differently
OPENAI_API_KEY=

# [OPTIONAL] Set to 1 to return a mock LLM response when the endpoint is down
ALLOW_MOCK_FALLBACK=1