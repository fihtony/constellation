# UI Design Agent - Minimal Configuration
# Copy to .env and fill in the REQUIRED values.

# [REQUIRED] Figma personal access token
# Generate at: https://www.figma.com/settings -> Personal access tokens
FIGMA_TOKEN=

# [REQUIRED] Google Stitch / Gemini API key
# Obtain at: https://aistudio.google.com/app/apikey
STITCH_API_KEY=

# [OPTIONAL] Corporate CA bundle for HTTPS behind a MITM proxy
# CORP_CA_BUNDLE=/app/certs/corp-ca.pem

# [OPTIONAL] Figma rate-limit tuning
# Minimum seconds between consecutive Figma API calls (default: 8 — safe for Dev/Full 10/min Tier-1 limit).
# FIGMA_MIN_CALL_INTERVAL_SECONDS=8
# Maximum seconds to wait on a 429 Retry-After response (default: 0 = honour header fully, no cap).
# FIGMA_MAX_RETRY_WAIT_SECONDS=0

# [OPTIONAL] Agent runtime + LLM settings
# AGENT_RUNTIME=copilot-cli
# AGENT_MODEL=gpt-5-mini
# OPENAI_BASE_URL=
#   Runtime-aware default when unset:
#   localhost on host, host.docker.internal in Docker,
#   host.rancher-desktop.internal in Rancher
# OPENAI_MODEL=gpt-5-mini
# COPILOT_GITHUB_TOKEN=<your-copilot-github-token>
