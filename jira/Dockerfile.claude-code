# Jira Agent — claude-code backend
# Extends constellation-base-claude-code with jira agent code.
# Select this Dockerfile when AGENT_RUNTIME=claude-code.

FROM constellation-base-claude-code:latest

COPY jira/   /app/jira/
COPY .github/skills/ /app/.github/skills/

LABEL constellation.agent_id="tracker-agent"
LABEL constellation.agent_name="Tracker Agent"
LABEL constellation.agent_role="fundamental"
LABEL constellation.runtime.backend="claude-code"

RUN chown -R appuser:appuser /app
USER appuser

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "jira/app.py"]
