# =============================================================================
# Jira Agent — Minimal Configuration
# Copy to .env and fill in the REQUIRED values.
# All other settings have sensible defaults and rarely need to change.
# =============================================================================

# [REQUIRED] Jira API token — generate at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# [REQUIRED] Atlassian account email used with JIRA_TOKEN
JIRA_EMAIL=

# [REQUIRED] Base URL of your Jira Cloud site
JIRA_BASE_URL=https://your-org.atlassian.net

# [OPTIONAL] Override the REST v3 base URL (derived from JIRA_BASE_URL when omitted)
# JIRA_API_BASE_URL=https://your-org.atlassian.net/rest/api/3

# [OPTIONAL] Authentication mode: basic | bearer  (default: basic)
# JIRA_AUTH_MODE=basic

# [OPTIONAL] Back-end selector: rest | mcp  (default: rest)
# rest — Jira REST API v3 (direct HTTP calls to your Jira site)
# mcp  — Atlassian Rovo MCP server (https://mcp.atlassian.com/v1/mcp)
#         requires the same JIRA_TOKEN / JIRA_EMAIL; MCP API token auth must be
#         enabled in Atlassian Admin → Security → MCP Server settings.
# JIRA_BACKEND=rest

# [OPTIONAL] Atlassian Rovo MCP server URL (rarely needs changing)
# ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp

# [OPTIONAL] Agent identity and registry
# AGENT_ID=jira-agent
# ADVERTISED_BASE_URL=http://jira:8010
# REGISTRY_URL=http://registry:9000
# ORCHESTRATOR_URL=http://compass:8080
# HOST=0.0.0.0
# PORT=8010
# HEARTBEAT_INTERVAL=30

# [OPTIONAL] LLM configuration
# AGENT_RUNTIME=copilot-cli
# AGENT_MODEL=gpt-5-mini
# OPENAI_BASE_URL=
#   Runtime-aware default when unset:
#   localhost on host, host.docker.internal in Docker,
#   host.rancher-desktop.internal in Rancher
# OPENAI_MODEL=gpt-5-mini
# OPENAI_API_KEY=

# [OPTIONAL] GitHub PAT for Copilot CLI if this persistent agent should use the CLI path
# COPILOT_GITHUB_TOKEN=<your-copilot-github-token>
