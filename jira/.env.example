# =============================================================================
# Jira Agent — Environment Configuration
# Copy this file to .env and fill in the required values.
#
# Legend:  [REQUIRED] must be set for the agent to function correctly
#          [OPTIONAL] has a default; override only when needed
# =============================================================================

# -----------------------------------------------------------------------------
# Jira Cloud credentials
# -----------------------------------------------------------------------------

# [REQUIRED] Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=replace-with-jira-token

# [REQUIRED] Atlassian account email paired with JIRA_TOKEN for Basic auth
JIRA_EMAIL=jira-user@example.com

# -----------------------------------------------------------------------------
# Jira instance configuration
# -----------------------------------------------------------------------------

# [OPTIONAL] Base URL of your Jira Cloud site
JIRA_BASE_URL=https://your-org.atlassian.net

# [OPTIONAL] REST API v3 base URL (derived from JIRA_BASE_URL when omitted)
JIRA_API_BASE_URL=https://your-org.atlassian.net/rest/api/3

# [OPTIONAL] Authentication mode: basic (email:token) or bearer
JIRA_AUTH_MODE=basic

# [OPTIONAL] Jira Cloud ID — required only for OAuth 2.0 flows
JIRA_CLOUD_ID=

# -----------------------------------------------------------------------------
# Agent identity
# -----------------------------------------------------------------------------

# [OPTIONAL] Unique agent identifier — must match registry-config.json
HOST=0.0.0.0

# [OPTIONAL] Port the agent listens on
PORT=8010

# [OPTIONAL] Unique agent identifier
AGENT_ID=jira-agent

# [OPTIONAL] URL that other agents use to reach this instance
ADVERTISED_BASE_URL=http://jira:8010

# [OPTIONAL] Capability Registry URL
REGISTRY_URL=http://registry:9000

# [OPTIONAL] Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# [OPTIONAL] Set to 0 to disable registry heartbeat (useful for unit tests)
INSTANCE_REPORTER_ENABLED=1

# -----------------------------------------------------------------------------
# LLM backend
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenAI-compatible endpoint
OPENAI_BASE_URL=http://host.docker.internal:1288/v1

# [OPTIONAL] Model name served at OPENAI_BASE_URL
OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] API key — leave blank when the endpoint handles auth differently
OPENAI_API_KEY=

# [OPTIONAL] Set to 1 to return a mock LLM response when the endpoint is down
ALLOW_MOCK_FALLBACK=1