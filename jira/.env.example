# =============================================================================
# Jira Agent — Minimal Configuration
# Copy to .env and fill in the REQUIRED values.
# All other settings have sensible defaults and rarely need to change.
# =============================================================================

# [REQUIRED] Jira API token — generate at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# [REQUIRED] Atlassian account email used with JIRA_TOKEN
JIRA_EMAIL=

# [REQUIRED] Base URL of your Jira Cloud site
JIRA_BASE_URL=https://your-org.atlassian.net

# [OPTIONAL] Override the REST v3 base URL (derived from JIRA_BASE_URL when omitted)
# JIRA_API_BASE_URL=https://your-org.atlassian.net/rest/api/3

# [OPTIONAL] Authentication mode: basic | bearer  (default: basic)
# JIRA_AUTH_MODE=basic
