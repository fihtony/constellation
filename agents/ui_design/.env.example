# UI Design Agent — credentials and deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Non-credential config (runtime backend, model, registry) inherits from
# config/constellation.yaml via the unified config loader. Only put secrets
# and deployment-specific overrides here.
#
# This agent bridges two design providers:
#   figma.*   → Figma REST API v1 (personal access token)
#   stitch.*  → Google Stitch MCP  (Google / Gemini API key)
# Both are optional; enable only the providers you use.

# ----- Figma (optional) -----

# Figma personal access token — generate at https://www.figma.com/settings → Access tokens
# Required for figma.file.fetch / figma.page.fetch capabilities.
FIGMA_TOKEN=

# ----- Google Stitch MCP (optional) -----

# Google / Gemini API key with Stitch access
# Required for stitch.screen.fetch / stitch.screen.list capabilities.
STITCH_API_KEY=

# ----- OPTIONAL: Figma rate-limit tuning -----
# Minimum seconds between Figma API calls (default: 8, Figma Tier-1 budget)
# FIGMA_RATE_INTERVAL=8

# ----- OPTIONAL: service port (overrides config.yaml) -----
# PORT=8040
