# Web Dev Agent — deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Non-credential config (runtime, model, registry) inherits from
# config/constellation.yaml. Git credentials for cloning/pushing must
# be set here (never committed).

# ----- REQUIRED for repo operations -----

# GitHub personal access token (classic) with repo scope, or fine-grained PAT.
# Used by git clone / push over HTTPS as: https://<user>:<token>@github.com/...
# Also read by the GitHub MCP backend when SCM_BACKEND=mcp.
GH_TOKEN=

# GitHub username (required when GH_TOKEN is a classic PAT for HTTPS push)
# GH_USERNAME=

# ----- OPTIONAL: service binding -----
# HOST=0.0.0.0
# PORT=8050

# ----- OPTIONAL: runtime override (inherits connect-agent from global) -----
# AGENT_RUNTIME=connect-agent
# OPENAI_API_KEY=
