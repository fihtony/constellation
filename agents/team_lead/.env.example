# Team Lead Agent — deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Team Lead orchestrates Jira, UI Design, Web Dev, and Code Review agents.
# Non-credential config inherits from config/constellation.yaml.
# Put service URL overrides here when agents run on non-default ports.

# ----- OPTIONAL: downstream agent URL overrides -----
# (defaults come from config/constellation.yaml > services section)
# JIRA_AGENT_URL=http://jira:8010
# UI_DESIGN_AGENT_URL=http://ui-design:8040
# WEB_DEV_AGENT_URL=http://web-dev:8050
# CODE_REVIEW_AGENT_URL=http://code-review:8060

# ----- OPTIONAL: service binding -----
# HOST=0.0.0.0
# PORT=8030

# ----- OPTIONAL: runtime override (inherits connect-agent from global) -----
# AGENT_RUNTIME=connect-agent
# OPENAI_API_KEY=
