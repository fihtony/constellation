# Jira Agent — credentials and deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Non-credential config (runtime backend, model, registry) inherits from
# config/constellation.yaml via the unified config loader. Only put secrets
# and deployment-specific overrides here.

# ----- REQUIRED: Jira Cloud credentials -----

# Atlassian site root (e.g. https://your-org.atlassian.net)
JIRA_BASE_URL=

# Atlassian API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# Atlassian account email (used for Basic auth alongside the API token)
JIRA_EMAIL=

# ----- OPTIONAL: Jira auth / TLS -----

# Auth mode: basic (default, email+token) | bearer (token only, e.g. on-prem PAT)
# JIRA_AUTH_MODE=basic

# Path to a corporate CA bundle for on-prem / self-signed TLS
# JIRA_CA_BUNDLE=

# ----- OPTIONAL: service port (overrides config.yaml) -----
# PORT=8010
