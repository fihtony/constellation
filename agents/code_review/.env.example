# Code Review Agent — deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Code Review only reads repos and PRs (no write permissions).
# Non-credential config inherits from config/constellation.yaml.

# ----- OPTIONAL: read-only SCM token for PR diff access -----
# GitHub read-only PAT (contents: read, pull-requests: read)
# GH_TOKEN=

# ----- OPTIONAL: service binding -----
# HOST=0.0.0.0
# PORT=8060

# ----- OPTIONAL: runtime override (inherits connect-agent from global) -----
# AGENT_RUNTIME=connect-agent
# OPENAI_API_KEY=
