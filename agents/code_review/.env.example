# Code Review Agent — deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Code Review receives PR diffs and context from Team Lead via A2A metadata.
# It does NOT access git repos directly — all SCM operations go through the
# SCM Agent boundary. No git credentials are needed here.
#
# Non-credential config inherits from config/constellation.yaml.

# ----- OPTIONAL: service binding -----
# HOST=0.0.0.0
# PORT=8060
