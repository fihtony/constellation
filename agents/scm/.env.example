# SCM Agent — credentials and deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Non-credential config (runtime backend, model, registry) inherits from
# config/constellation.yaml via the unified config loader. Only put secrets
# and deployment-specific overrides here.
#
# Provider is auto-detected from SCM_BASE_URL:
#   github.com  → GitHub REST API
#   bitbucket.* → Bitbucket Server REST 1.0

# ----- REQUIRED: SCM base URL -----

# GitHub:              https://github.com
# Bitbucket Server:    https://bitbucket.your-org.com
SCM_BASE_URL=

# ----- REQUIRED: token -----

# GitHub:           personal access token (classic) with repo scope,
#                   or fine-grained PAT with Contents + Pull Requests write
# Bitbucket Server: personal access token (HTTP Bearer)
SCM_TOKEN=

# ----- OPTIONAL: Bitbucket username (required for HTTP Basic auth) -----
# Leave empty when using Bearer token auth (GitHub or Bitbucket PAT).
# SCM_USERNAME=

# ----- OPTIONAL: Bitbucket default project key -----
# Used when the project key cannot be parsed from a repo URL.
# SCM_DEFAULT_PROJECT=

# ----- OPTIONAL: TLS -----
# Path to a corporate CA bundle for self-signed TLS on Bitbucket Server.
# SCM_CA_BUNDLE=

# ----- OPTIONAL: service port (overrides config.yaml) -----
# PORT=8020
