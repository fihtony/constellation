# SCM Agent — credentials and deployment config
# Copy to .env and fill in your values (never commit .env).
#
# Non-credential config (runtime backend, model, registry) inherits from
# config/constellation.yaml via the unified config loader. Only put secrets
# and deployment-specific overrides here.
#
# Backend selection (default: auto-detect from SCM_BASE_URL):
#   bitbucket   → Bitbucket Server REST 1.0 (default for self-hosted)
#   github-rest → GitHub REST API v3
#   github-mcp  → GitHub MCP (remote cloud MCP server, advanced)
#
# Auto-detection rules (when SCM_BACKEND is unset):
#   *.bitbucket.* in SCM_BASE_URL  → bitbucket
#   github.com in SCM_BASE_URL     → github-rest
#   anything else                  → bitbucket

# ----- OPTIONAL: explicit backend override -----
# SCM_BACKEND=bitbucket

# ----- REQUIRED: SCM base URL -----

# Bitbucket Server:    https://bitbucket.your-org.com
# GitHub:              https://github.com  (or leave empty for github-rest)
SCM_BASE_URL=

# ----- REQUIRED: token -----

# Bitbucket Server: personal access token (HTTP Bearer)
#   or username + password for HTTP Basic.
# GitHub REST:      personal access token (classic) with repo scope,
#                   or fine-grained PAT (Contents + Pull Requests write).
# GitHub MCP:       GitHub personal access token (same as github-rest).
SCM_TOKEN=

# ----- OPTIONAL: username (Bitbucket Basic auth only) -----
# Required for Bitbucket when using a password instead of a PAT Bearer token.
# Leave empty for GitHub or Bitbucket Bearer-token auth.
# SCM_USERNAME=

# ----- OPTIONAL: Bitbucket default project key -----
# Used when the project key cannot be parsed from a repo URL.
# SCM_DEFAULT_PROJECT=

# ----- OPTIONAL: TLS (Bitbucket Server only) -----
# Path to a corporate CA bundle for self-signed TLS on Bitbucket Server.
# SCM_CA_BUNDLE=

# ----- OPTIONAL: service port (overrides config.yaml) -----
# PORT=8020
