# Shared Constellation runtime configuration.
# Copy this file to common/.env. It is loaded before each agent's local .env,
# so agent-specific .env files can still override shared defaults.

# ---------------------------------------------------------------------------
# [OPTIONAL but recommended] Shared local timestamp configuration
# Used by workspace folder names, command-log.txt, stage-summary.json, and audit logs.
# Examples: America/Toronto, America/Vancouver, Europe/Berlin, Asia/Shanghai
# ---------------------------------------------------------------------------
LOCAL_TIMEZONE=UTC

# ---------------------------------------------------------------------------
# [OPTIONAL but recommended] Container runtime used by the launcher and
# runtime-aware Copilot Connect host resolution.
# Set this in common/.env to switch the launcher backend globally unless a
# specific agent intentionally overrides it in its own local .env.
# Supported: docker | rancher
# Docker remains the default when unset.
# ---------------------------------------------------------------------------
# CONTAINER_RUNTIME=docker

# [OPTIONAL] Docker-compatible socket path visible to the current process.
# - Host process + Rancher Desktop: set to an absolute host path such as
#   /Users/yourname/.rd/docker.sock when needed.
# - Containers launched through docker-compose use /var/run/docker.sock inside
#   the container; the launcher auto-discovers the corresponding host source.
# DOCKER_SOCKET=

# ---------------------------------------------------------------------------
# [OPTIONAL] Unified agentic runtime selection for all LLM-enabled agents.
# Shared defaults belong here; per-task launchSpec.env should override only
# when an agent must intentionally diverge from the common baseline.
# Supported: copilot-cli | connect-agent | claude-code
# Registry remains non-agentic; Compass also uses the selected agentic runtime.
# ---------------------------------------------------------------------------
AGENT_RUNTIME=copilot-cli

# [OPTIONAL] Shared model override for all agentic backends.
# Backend-specific model settings should live in the agent-local .env only when
# a specific agent intentionally diverges from the shared baseline.
AGENT_MODEL=gpt-5-mini

# ---------------------------------------------------------------------------
# [OPTIONAL for connect-agent] OpenAI-compatible endpoint configuration
# Used by: connect-agent runtime when it is selected explicitly.
# Leave OPENAI_BASE_URL unset to use runtime-aware defaults:
#   - host process / standalone debug: http://localhost:1288/v1
#   - Docker container: http://host.docker.internal:1288/v1
#   - Rancher container: http://host.rancher-desktop.internal:1288/v1
# Set OPENAI_BASE_URL explicitly only for a custom host or port.
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# [OPTIONAL for connect-agent] Built-in runtime controls
# ---------------------------------------------------------------------------
# CONNECT_AGENT_PROFILE=workspace-write
# CONNECT_AGENT_SANDBOX_ROOT=
# CONNECT_AGENT_MAX_TURNS=50
# CONNECT_AGENT_TIMEOUT=1800
# CONNECT_AGENT_TOKEN_THRESHOLD=100000
# CONNECT_AGENT_POLICY_FILE=
# CONNECT_AGENT_CHECKPOINT_DIR=
# CONNECT_AGENT_MCP_CONFIG=
# CONNECT_AGENT_MCP_ALLOWLIST=
# CONNECT_AGENT_ALLOWED_MCP_SERVERS=

# ---------------------------------------------------------------------------
# [MANDATORY for copilot-cli] GitHub Copilot CLI authentication
# Required only when AGENT_RUNTIME=copilot-cli.
# If a custom CLI binary path is needed, set it in the agent-local .env rather
# than in this shared default file.
# ---------------------------------------------------------------------------
COPILOT_GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# [OPTIONAL for claude-code] Claude Code CLI configuration
# Required only when AGENT_RUNTIME=claude-code.
# If a custom binary path or model override is needed, set it in the agent-local
# .env rather than in this shared default file.
# ---------------------------------------------------------------------------