# Shared Constellation runtime configuration.
# Copy this file to common/.env. It is loaded before each agent's local .env,
# so agent-specific .env files can still override shared defaults.

# ---------------------------------------------------------------------------
# [OPTIONAL but recommended] Shared local timestamp configuration
# Used by workspace folder names, command-log.txt, stage-summary.json, and audit logs.
# Examples: America/Toronto, America/Vancouver, Europe/Berlin, Asia/Shanghai
# ---------------------------------------------------------------------------
LOCAL_TIMEZONE=UTC

# ---------------------------------------------------------------------------
# [OPTIONAL] Unified agentic runtime selection for all LLM-enabled agents
# Supported: copilot-cli | claude-code | copilot-connect | mock
# Compass and Registry are intentionally non-agentic control-plane services.
# ---------------------------------------------------------------------------
AGENT_RUNTIME=copilot-connect

# [OPTIONAL] Shared model override. Precedence by backend:
#   1. AGENT_MODEL
#   2. backend-specific model (COPILOT_MODEL / CLAUDE_CODE_MODEL / OPENAI_MODEL)
#   3. backend built-in default
AGENT_MODEL=gpt-5-mini

# ---------------------------------------------------------------------------
# [MANDATORY for copilot-connect] OpenAI-compatible endpoint configuration
# Used by: copilot-connect backend and fallback paths from copilot-cli / claude-code.
# ---------------------------------------------------------------------------
OPENAI_BASE_URL=http://host.docker.internal:1288/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=

# [OPTIONAL] Allow deterministic mock fallback only for tests/offline validation.
# Keep disabled in development and production environments.
ALLOW_MOCK_FALLBACK=0

# ---------------------------------------------------------------------------
# [MANDATORY for copilot-cli] GitHub Copilot CLI authentication
# Required only when AGENT_RUNTIME=copilot-cli.
# ---------------------------------------------------------------------------
COPILOT_GITHUB_TOKEN=
COPILOT_MODEL=gpt-5-mini
COPILOT_CLI_BIN=copilot
COPILOT_CLI_ARGS=

# ---------------------------------------------------------------------------
# [OPTIONAL for claude-code] Claude Code CLI configuration
# Required only when AGENT_RUNTIME=claude-code.
# ---------------------------------------------------------------------------
CLAUDE_CODE_BIN=claude
CLAUDE_CODE_MODEL=claude-haiku-4-5
CLAUDE_CODE_ARGS=

# ---------------------------------------------------------------------------
# [OPTIONAL for mock] Deterministic unit/integration test response.
# Keep unset outside test-only environments.
# ---------------------------------------------------------------------------
MOCK_RUNTIME_RESPONSE=