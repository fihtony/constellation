# =============================================================================
# Android Agent — Minimal Configuration
# Launched as a per-task container; most settings come from docker-compose.
# =============================================================================

# [OPTIONAL] Override the LLM endpoint (runtime-aware default used when unset)
# OPENAI_BASE_URL=

# [OPTIONAL] Agentic runtime backend: connect-agent | copilot-cli | claude-code
# AGENT_RUNTIME=connect-agent

# [OPTIONAL] LLM model override
# AGENT_MODEL=gpt-5-mini
# OPENAI_MODEL=gpt-5-mini

# [OPTIONAL] LLM API key (not needed for connect-agent)
# OPENAI_API_KEY=

# [OPTIONAL] Container-safe Gradle tuning for Android builds/tests
#   Defaults are chosen for the per-task amd64 container profile validated in Constellation.
# ANDROID_GRADLE_MAX_WORKERS=1
# ANDROID_GRADLE_JVM_ARGS=-Xmx640m -Dfile.encoding=UTF-8

# [OPTIONAL] Allow mock fallback when no LLM backend is available
ALLOW_MOCK_FALLBACK=0

# [OPTIONAL] Copilot GitHub token for CLI backend
# COPILOT_GITHUB_TOKEN=<your-copilot-github-token>
