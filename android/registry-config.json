{
  "agentId": "android-agent",
  "cardUrl": "http://android-agent:8000/.well-known/agent-card.json",
  "executionMode": "per-task",
  "launchSpec": {
    "image": "constellation-android-agent:latest",
    "platform": "linux/amd64",
    "port": 8000,
    "memory": "4g",
    "command": ["python3", "android/app.py"],
    "passThroughEnv": ["ARTIFACT_ROOT", "DYNAMIC_AGENT_NETWORK", "COPILOT_GITHUB_TOKEN", "TZ"],
    "env": {},
    "mountDockerSocket": false
  },
  "scalingPolicy": {
    "maxInstances": 3,
    "perInstanceConcurrency": 1,
    "idleTimeoutSeconds": 120
  }
}
