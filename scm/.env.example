# =============================================================================
# SCM Agent - Minimal Configuration
# Copy to .env and fill in the REQUIRED values.
# All other settings have sensible defaults and rarely need to change.
# =============================================================================

# [REQUIRED] GitHub personal access token (scope: repo)
# For Bitbucket, set SCM_PROVIDER=bitbucket below and use your Bitbucket token
SCM_TOKEN=

# [OPTIONAL] GitHub username (only needed for Basic auth; Bearer is preferred)
# SCM_USERNAME=

# =============================================================================
# Provider (default: github)
#   github    - GitHub REST API (api.github.com)
#   bitbucket - Bitbucket Server REST API (requires SCM_BASE_URL below)
# =============================================================================
# SCM_PROVIDER=github

# ===========================================================# ===========================================================# ======wh# ===========================================================# =================# ==============================BASE# ============================================PR# ===========================================================# ======PROJECT
# SCM_AUTH_MODE=bearer
# CORP_CA_BUNDLE=/app/certs/corp-ca.pem
