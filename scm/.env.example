# =============================================================================
# SCM Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# Agent identity
AGENT_ID=scm-agent
ADVERTISED_BASE_URL=http://scm:8020

# Registry
REGISTRY_URL=http://registry:9000

# =============================================================================
# Provider selection
#
#   SCM_PROVIDER=github      → GitHub REST API (api.github.com)
#   SCM_PROVIDER=bitbucket   → Bitbucket Server REST API
#
# If omitted, auto-detected from SCM_BASE_URL:
#   - URL containing "github.com" or empty → github
#   - Any other URL → bitbucket
# =============================================================================
SCM_PROVIDER=github

# =============================================================================
# GitHub provider
# =============================================================================
# GitHub personal access token (scope: repo)
SCM_TOKEN=

# GitHub username (optional — only needed if using Basic auth instead of Bearer)
SCM_USERNAME=

# =============================================================================
# Bitbucket Server provider
# =============================================================================
# Base URL of your Bitbucket Server project
# Example: https://bitbucket.example.com/projects/MYPROJECT
SCM_BASE_URL=https://bitbucket.example.com/projects/MYPROJECT

# Bitbucket API token
# SCM_TOKEN=

# Bitbucket username (required for Basic auth)
# SCM_USERNAME=

# Authentication mode: auto | basic | bearer  (default: auto)
SCM_AUTH_MODE=auto

# Default Bitbucket project key (used when project is not specified in requests)
SCM_DEFAULT_PROJECT=MYPROJECT

# Corporate CA bundle (optional — for self-signed certs in Bitbucket Server)
CORP_CA_BUNDLE=

# =============================================================================
# Git commit author
# =============================================================================
SCM_GIT_AUTHOR_NAME=SCM Agent
SCM_GIT_AUTHOR_EMAIL=scm-agent@local

# =============================================================================
# LLM (for free-form message dispatch)
# =============================================================================
OPENAI_BASE_URL=http://host.docker.internal:1288/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
ALLOW_MOCK_FALLBACK=1

# =============================================================================
# Runtime
# =============================================================================
HOST=0.0.0.0
PORT=8020
HEARTBEAT_INTERVAL=30
CLONE_TIMEOUT_SECONDS=600
REPO_TREE_MAX_FILES=500
