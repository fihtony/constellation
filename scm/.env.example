# =============================================================================
# SCM Agent — Configuration
# Copy to .env and fill in the REQUIRED values.
# All other settings have sensible defaults and rarely need to change.
# =============================================================================

# [REQUIRED] SCM token.
#
# For GITHUB (fine-grained personal access token):
#   Create at: https://github.com/settings/tokens?type=beta
#   Token type: Fine-grained PAT (preferred) or classic PAT (scope: repo)
#
#   Required fine-grained repository permissions:
#     - Contents:       Read and write   (git clone, git push, branch creation)
#     - Pull requests:  Read and write   (create PR, list PRs, get PR, inline PR comments)
#     - Issues:         Read and write   (general PR comments use the Issues API)
#     - Metadata:       Read-only        (required by GitHub, always included automatically)
#
# For BITBUCKET Server:
#   Use a personal access token with repo read+write permissions.
SCM_TOKEN=

# [OPTIONAL] Username — only needed for Basic auth with Bitbucket.
# GitHub fine-grained PATs use Bearer auth and do NOT need a username.
# SCM_USERNAME=

# =============================================================================
# Provider selection (default: github when SCM_BASE_URL is not set)
#   github    - GitHub.com  (REST API or MCP, controlled by SCM_BACKEND below)
#   bitbucket - Bitbucket Server REST API  (set SCM_BASE_URL below)
# =============================================================================
SCM_PROVIDER=github

# =============================================================================
# Back-end selector (only applies when SCM_PROVIDER=github)
#   rest  (default) — GitHub REST API + git CLI.  Only SCM_TOKEN is required.
#   mcp             — Remote GitHub MCP server (https://api.githubcopilot.com/mcp/).
#                     Uses the same SCM_TOKEN; no local Docker/npx needed.
# =============================================================================
# SCM_BACKEND=rest

# =============================================================================
# Bitbucket-only settings (leave commented out when using GitHub)
# =============================================================================
# SCM_BASE_URL=https://bitbucket.example.com
# SCM_DEFAULT_PROJECT=MYPROJ
# SCM_AUTH_MODE=bearer
# CORP_CA_BUNDLE=/app/certs/corp-ca.pem

# =============================================================================
# Optional overrides
# =============================================================================
# AGENT_RUNTIME=copilot-cli
# AGENT_MODEL=gpt-5-mini
# OPENAI_BASE_URL=http://host.docker.internal:1288/v1
# OPENAI_MODEL=gpt-5-mini
# ALLOW_MOCK_FALLBACK=1
# COPILOT_GITHUB_TOKEN=github_pat_...
# SCM_GIT_AUTHOR_NAME=SCM Agent
# SCM_GIT_AUTHOR_EMAIL=scm-agent@local
# CLONE_TIMEOUT_SECONDS=600
