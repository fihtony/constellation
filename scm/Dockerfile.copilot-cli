# SCM Agent — copilot-cli backend
# Extends constellation-base-copilot-cli with scm agent code.
# Select this Dockerfile when AGENT_RUNTIME=copilot-cli (the default).

FROM constellation-base-copilot-cli:latest

COPY scm/     /app/scm/
COPY .github/skills/ /app/.github/skills/

ENV SCM_GITHUB_BACKEND=rest \
    MCP_RUNNER=auto

LABEL constellation.agent_id="scm-agent"
LABEL constellation.agent_name="SCM Agent"
LABEL constellation.agent_role="integration"
LABEL constellation.runtime.backend="copilot-cli"

RUN chown -R appuser:appuser /app
USER appuser

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "scm/app.py"]
