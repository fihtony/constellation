# Agent identity
AGENT_ID=im-gateway
ADVERTISED_BASE_URL=http://im-gateway:8070

# Registry
REGISTRY_URL=http://registry:9000

# Compass
COMPASS_URL=http://compass:8080
COMPASS_API_KEY=

# --- Microsoft Teams Connector ---
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=

# --- Slack Connector ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# SQLite persistence
IM_GATEWAY_DB_PATH=/app/data/im-gateway/im-gateway.db

# Rate limiting
MAX_TASKS_PER_USER=5
RATE_LIMIT_PER_MINUTE=3
MAX_MESSAGE_LENGTH=4000

# Runtime
HOST=0.0.0.0
PORT=8070
